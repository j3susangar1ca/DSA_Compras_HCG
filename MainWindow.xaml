<Window
    x:Class="DSA_Compras_HCG.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <NavigationView x:Name="NavView" 
                        IsBackButtonVisible="Collapsed" 
                        PaneDisplayMode="Auto">

            <NavigationView.MenuItems>
                <NavigationViewItem Icon="Home" Content="Dashboard" Tag="Home"/>
                <NavigationViewItem Icon="Add" Content="Nuevo Pedido" Tag="NuevoPedido"/>
                <NavigationViewItem Icon="Library" Content="Catálogo (63k)" Tag="Catalogo"/>
                <NavigationViewItem Icon="Sync" Content="Reintegros Semanales" Tag="Reintegros"/>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Icon="Settings" Content="Configuración" Tag="Config"/>
            </NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame" Padding="24" />

        </NavigationView>
    </Grid>
</Window>